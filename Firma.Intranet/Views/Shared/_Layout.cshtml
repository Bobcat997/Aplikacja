<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Intranet Szczypka Elite</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    
    <style>
            body {
                background-color: #0f0f0f;
                color: #e0e0e0;
            }

            .navbar {
                background: linear-gradient(90deg, #1f1f1f, #2d2d2d) !important;
                border-bottom: 6px solid #f1c40f;
            }

            .sidebar {
                background-color: #1a1a1a;
                min-height: 100vh;
                border-right: 2px solid #333;
            }

            .nav-link {
                color: #ffffff !important;
                padding: 14px 20px;
                font-weight: 500;
                transition: 0.2s;
            }

                .nav-link:hover,
                .nav-link.active {
                    background-color: #e63939;
                    color: #ffffff !important;
                }

            .card {
                background-color: #1f1f1f;
                border: none;
            }
    </style>
</head>
<body>

    @{
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-dumbbell"></i> SZCZYPKA ELITE INTRANET
            </a>

            <span class="navbar-text">
                <i class="fas fa-user"></i> Bartłomiej Szczypka (Trener)
            </span>

            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link @(currentAction == "Dashboard" ? "active" : "")" href="/Home/Dashboard">Dashboard</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentAction == "Grafik" ? "active" : "")" href="/Home/Grafik">Grafik</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentAction == "Klienci" ? "active" : "")" href="/Home/Klienci">Klienci</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentAction == "Sprzet" ? "active" : "")" href="/Home/Sprzet">Sprzęt</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentAction == "Raporty" ? "active" : "")" href="/Home/Raporty">Raporty</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-warning" href="#">Wyloguj</a>
                </li>
            </ul>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
        
            <div class="col-md-2 sidebar py-4">
                <h6 class="text-white px-3 mb-3">NAWIGACJA</h6>
            
                <ul class="nav flex-column">
                    <li>
                        <a class="nav-link @(currentAction == "Dashboard" ? "active" : "")" href="/Home/Dashboard">
                            <i class="fas fa-home me-2"></i> Panel główny
                        </a>
                    </li>
                
                    <li>
                        <a class="nav-link @(currentAction == "Grafik" ? "active" : "")" href="/Home/Grafik">
                            <i class="fas fa-calendar me-2"></i> Harmonogram
                        </a>
                    </li>
                
                    <li>
                        <a class="nav-link @(currentAction == "Klienci" ? "active" : "")" href="/Home/Klienci">
                            <i class="fas fa-users me-2"></i> Członkowie
                        </a>
                    </li>
                
                    <li>
                        <a class="nav-link @(currentAction == "Sprzet" ? "active" : "")" href="/Home/Sprzet">
                            <i class="fas fa-dumbbell me-2"></i> Sprzęt
                        </a>
                    </li>
                
                    <li>
                        <a class="nav-link @(currentAction == "Raporty" ? "active" : "")" href="/Home/Raporty">
                            <i class="fas fa-chart-bar me-2"></i> Raporty
                        </a>
                    </li>
                </ul>
            </div>

            <div class="col-md-10 p-5">
                @RenderBody()
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>