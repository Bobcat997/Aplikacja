<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Firma Intranet</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    
    <style>
            body {
                background-color: #0f0f0f;
                color: #e0e0e0;
            }

            .navbar {
                background: linear-gradient(90deg, #1f1f1f, #2d2d2d) !important;
                border-bottom: 6px solid #3498db; /* niebieski zamiast żółtego */
            }

            .sidebar {
                background-color: #1a1a1a;
                min-height: 100vh;
                border-right: 2px solid #333;
            }

            .nav-link {
                color: #ffffff !important;
                padding: 14px 20px;
                font-weight: 500;
                transition: 0.2s;
            }

                .nav-link:hover,
                .nav-link.active {
                    background-color: #3498db; /* niebieski hover */
                    color: #ffffff !important;
                }

            .card {
                background-color: #1f1f1f;
                border: none;
            }
    </style>
</head>
<body>

    @{
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    }

    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-building"></i> FIRMA INTRANET
            </a>

            <span class="navbar-text">
                <i class="fas fa-user"></i> Zalogowany: Admin
            </span>

            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Home" && currentAction == "Dashboard" ? "active" : "")"
                       href="/Home/Dashboard">Dashboard</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Home" && currentAction == "Raporty" ? "active" : "")"
                       href="/Home/Raporty">Raporty</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-warning" href="#">Wyloguj</a>
                </li>
            </ul>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2 sidebar py-4">
                <h6 class="text-white px-3 mb-3">MODUŁY FIRMY</h6>
                
                <ul class="nav flex-column">
                    <!-- Stare linki (zachowane) -->
                    <li>
                        <a class="nav-link @(currentController == "Home" && currentAction == "Dashboard" ? "active" : "")"
                               href="/Home/Dashboard">
                            <i class="fas fa-home me-2"></i> Panel główny
                        </a>
                    </li>
                    <li>
                        <a class="nav-link @(currentController == "Home" && currentAction == "Raporty" ? "active" : "")"
                               href="/Home/Raporty">
                            <i class="fas fa-chart-bar me-2"></i> Raporty
                        </a>
                    </li>

                    <li><hr class="dropdown-divider bg-secondary mx-3"></li>

                    <!-- Nowe encje (CRUD) -->
                    <li>
                        <a class="nav-link @(currentController == "Pracownik" ? "active" : "")" href="/Pracownik">
                            <i class="fas fa-users me-2"></i> Pracownicy
                        </a>
                    </li>
                    <li>
                        <a class="nav-link @(currentController == "Dzial" ? "active" : "")" href="/Dzial">
                            <i class="fas fa-sitemap me-2"></i> Działy
                        </a>
                    </li>
                    <li>
                        <a class="nav-link @(currentController == "Stanowisko" ? "active" : "")" href="/Stanowisko">
                            <i class="fas fa-briefcase me-2"></i> Stanowiska
                        </a>
                    </li>
                    <li>
                        <a class="nav-link @(currentController == "Projekt" ? "active" : "")" href="/Projekt">
                            <i class="fas fa-folder me-2"></i> Projekty
                        </a>
                    </li>
                    <li>
                        <a class="nav-link @(currentController == "Klient" ? "active" : "")" href="/Klient">
                            <i class="fas fa-handshake me-2"></i> Klienci
                        </a>
                    </li>
                    <li>
                        <a class="nav-link @(currentController == "Zadanie" ? "active" : "")" href="/Zadanie">
                            <i class="fas fa-tasks me-2"></i> Zadania
                        </a>
                    </li>
                    <li>
                        <a class="nav-link @(currentController == "Urlop" ? "active" : "")" href="/Urlop">
                            <i class="fas fa-calendar-alt me-2"></i> Urlopy
                        </a>
                    </li>
                    <li>
                        <a class="nav-link @(currentController == "Sprzet" ? "active" : "")" href="/Sprzet">
                            <i class="fas fa-laptop me-2"></i> Sprzęt
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Główna zawartość -->
            <div class="col-md-10 p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>