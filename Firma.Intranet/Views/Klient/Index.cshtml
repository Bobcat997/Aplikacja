@{
    ViewBag.Title = "Klienci";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-handshake"></i> Klienci</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="fas fa-plus"></i> Dodaj klienta
    </a>
</div>

<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group w-50">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control" placeholder="Szukaj po nazwie firmy lub email..." />
        <button class="btn btn-primary" type="submit"><i class="fas fa-search"></i></button>
    </div>
</form>

<table class="table table-dark table-hover table-striped">
    <thead>
        <tr>
            <th>Nazwa firmy</th>
            <th>Osoba kontaktowa</th>
            <th>Email</th>
            <th>Telefon</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.NazwaFirmy</strong></td>
                <td>@item.ImieKontakt @item.NazwiskoKontakt</td>
                <td>@item.Email</td>
                <td>@item.Telefon</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                        <i class="fas fa-edit"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"
                           onclick="return confirm('Czy na pewno usunąć tego klienta?')">
                        <i class="fas fa-trash"></i>
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>