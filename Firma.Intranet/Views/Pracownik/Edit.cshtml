@model Firma.Data.Entities.Pracownik
@{
    ViewBag.Title = "Edytuj pracownika";
}

<h2><i class="fas fa-user-edit"></i> Edytuj pracownika</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="row">
        <div class="col-md-6">
            <label class="form-label">Imię</label>
            <input asp-for="Imie" class="form-control" required />
        </div>
        <div class="col-md-6">
            <label class="form-label">Nazwisko</label>
            <input asp-for="Nazwisko" class="form-control" required />
        </div>
    </div>

    <div class="mt-3">
        <label class="form-label">Email</label>
        <input asp-for="Email" type="email" class="form-control" />
    </div>

    <div class="mt-3">
        <label class="form-label">Telefon</label>
        <input asp-for="Telefon" class="form-control" />
    </div>

    <div class="row mt-3">
        <div class="col-md-6">
            <label class="form-label">Data zatrudnienia</label>
            <input asp-for="DataZatrudnienia" type="date" class="form-control" required />
        </div>
        <div class="col-md-6">
            <label class="form-label">Data zwolnienia</label>
            <input asp-for="DataZwolnienia" type="date" class="form-control" />
        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-warning btn-lg">💾 Zapisz zmiany</button>
        <a asp-action="Index" class="btn btn-secondary btn-lg">Anuluj</a>
    </div>
</form>