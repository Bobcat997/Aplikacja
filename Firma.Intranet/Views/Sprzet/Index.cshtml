@{
    ViewBag.Title = "Sprzęt";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-laptop"></i> Sprzęt</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="fas fa-plus"></i> Dodaj sprzęt
    </a>
</div>

<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group w-50">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control" placeholder="Szukaj po nazwie lub modelu..." />
        <button class="btn btn-primary" type="submit"><i class="fas fa-search"></i></button>
    </div>
</form>

<table class="table table-dark table-hover table-striped">
    <thead>
        <tr>
            <th>Nazwa</th>
            <th>Model</th>
            <th>Numer seryjny</th>
            <th>Przypisany do</th>
            <th>Status</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Nazwa</strong></td>
                <td>@item.Model</td>
                <td>@item.NumerSeryjny</td>
                <td>@item.Pracownik?.Imie @item.Pracownik?.Nazwisko</td>
                <td>@item.Status</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edytuj</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"
                       onclick="return confirm('Usunąć sprzęt?')">Usuń</a>
                </td>
            </tr>
        }
    </tbody>
</table>