@{
    ViewBag.Title = "Urlopy";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-calendar-alt"></i> Urlopy</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="fas fa-plus"></i> Dodaj urlop
    </a>
</div>

<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group w-50">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control" placeholder="Szukaj po pracowniku..." />
        <button class="btn btn-primary" type="submit"><i class="fas fa-search"></i></button>
    </div>
</form>

<table class="table table-dark table-hover table-striped">
    <thead>
        <tr>
            <th>Pracownik</th>
            <th>Typ urlopu</th>
            <th>Data od</th>
            <th>Data do</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Pracownik?.Imie @item.Pracownik?.Nazwisko</td>
                <td>@item.Typ</td>
                <td>@item.DataOd.ToShortDateString()</td>
                <td>@item.DataDo.ToShortDateString()</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edytuj</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"
                       onclick="return confirm('Usunąć urlop?')">Usuń</a>
                </td>
            </tr>
        }
    </tbody>
</table>