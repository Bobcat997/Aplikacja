<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Szczypka Elite</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    
    <style>
            :root {
                --red: #e63939;
                --dark: #0a0a0a;
            }

            body {
                background-color: var(--dark);
                color: #e0e0e0;
            }

            .navbar {
                background: rgba(10,10,10,0.97) !important;
                border-bottom: 5px solid var(--red);
            }

            .sidebar {
                background-color: #111;
                min-height: 100vh;
                border-right: 4px solid var(--red);
                padding-top: 100px;
            }

            .nav-link {
                color: #e0e0e0 !important;
                padding: 14px 25px;
                font-weight: 500;
            }

                .nav-link:hover, .nav-link.active {
                    background-color: var(--red);
                    color: white !important;
                }

            .main-content {
                padding: 30px;
                min-height: 100vh;
            }
    </style>
</head>
<body>

    <!-- Twój oryginalny navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/"><i class="fas fa-dumbbell"></i> Szczypka Elite</a>
            <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Oferta">Oferta</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Zajecia">Zajęcia</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Trenerzy">Trenerzy</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Kontakt">Kontakt</a></li>
                    <li class="nav-item ms-3">
                        <a class="btn btn-primary-custom" href="#">DOŁĄCZ TERAZ</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid" style="margin-top: 90px;">
        <div class="row">
            
            <!-- BOCZNY PANEL -->
            <div class="col-md-2 sidebar">
                <h5 class="px-3 mb-4 text-center text-danger">PORTAL</h5>
                <ul class="nav flex-column">
                    <li class="nav-item"><a class="nav-link" href="/Pracownik"><i class="fas fa-users"></i> Pracownicy</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Projekt"><i class="fas fa-folder"></i> Projekty</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Klient"><i class="fas fa-handshake"></i> Klienci</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Zadanie"><i class="fas fa-tasks"></i> Zadania</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Urlop"><i class="fas fa-calendar-alt"></i> Urlopy</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Dzial"><i class="fas fa-sitemap"></i> Działy</a></li>
                </ul>
            </div>

            <!-- Treść główna -->
            <div class="col-md-10 main-content">
                @RenderBody()
            </div>
        </div>
    </div>

    <footer class="py-5 text-center text-light">
        <div class="container">
            <p class="mb-0">&copy; 2026 Szczypka Elite • Siła • Determinacja • Wyniki</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>