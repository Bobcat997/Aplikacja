<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Szczypka Elite</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    
    <style>
            :root {
                --red: #e63939;
                --dark: #0a0a0a;
                --light: #f1f1f1;
            }

            body {
                background-color: var(--dark);
                color: #e0e0e0;
                font-family: 'Segoe UI', sans-serif;
            }

            .navbar {
                background: rgba(10,10,10,0.97) !important;
                backdrop-filter: blur(12px);
                border-bottom: 5px solid var(--red);
                box-shadow: 0 5px 20px rgba(230, 57, 57, 0.3);
            }

            .navbar-brand {
                font-size: 1.85rem;
                font-weight: 900;
                letter-spacing: 3px;
            }

            .nav-link {
                font-weight: 600;
                margin: 0 8px;
                transition: 0.3s;
            }

                .nav-link:hover {
                    color: var(--red) !important;
                }

            .hero {
                background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.85)), url('https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?auto=format&fit=crop&q=80') center/cover;
                height: 100vh;
                display: flex;
                align-items: center;
            }

            .btn-primary-custom {
                background: linear-gradient(45deg, #e63939, #ff5252);
                border: none;
                padding: 14px 38px;
                font-weight: 700;
                border-radius: 50px;
                box-shadow: 0 8px 25px rgba(230,57,57,0.4);
                transition: 0.4s;
            }

                .btn-primary-custom:hover {
                    transform: translateY(-6px);
                    box-shadow: 0 15px 35px rgba(230,57,57,0.5);
                }

            footer {
                background: #050505;
                border-top: 4px solid var(--red);
            }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/"><i class="fas fa-dumbbell"></i> Szczypka Elite</a>
            <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Oferta">Oferta</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Zajecia">Zajęcia</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Trenerzy">Trenerzy</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Kontakt">Kontakt</a></li>
                    <li class="nav-item ms-3">
                        <a class="btn btn-primary-custom" href="#">DOŁĄCZ TERAZ</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="py-5 text-center text-light">
        <div class="container">
            <p class="mb-0">&copy; 2026 Forge Fitness • Siła • Determinacja • Wyniki</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>