@model IEnumerable<Firma.Data.Entities.Dzial>
@{
    ViewBag.Title = "Działy";
}

<h2><i class="fas fa-sitemap"></i> Działy Firmy</h2>

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nazwa Dział</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Nazwa</strong></td>
            </tr>
        }
    </tbody>
</table>