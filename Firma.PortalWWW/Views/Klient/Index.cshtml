@model IEnumerable<Firma.Data.Entities.Klient>
@{
    ViewBag.Title = "Klienci";
}

<h2><i class="fas fa-handshake"></i> Nasi Klienci</h2>

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nazwa Firmy</th>
            <th>Osoba Kontaktowa</th>
            <th>Email</th>
            <th>Telefon</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.NazwaFirmy</strong></td>
                <td>@item.ImieKontakt @item.NazwiskoKontakt</td>
                <td>@item.Email</td>
                <td>@item.Telefon</td>
            </tr>
        }
    </tbody>
</table>