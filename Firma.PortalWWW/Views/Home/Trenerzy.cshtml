@{
    ViewBag.Title = "Trenerzy - Forge Fitness";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex align-items-center min-vh-100 pt-5">
    <div class="w-100">
        <h2 class="text-center display-5 fw-bold mb-5 text-light">Nasi Trenerzy</h2>
        
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card bg-dark text-center h-100">
                    <div class="card-body">
                        <i class="fas fa-user-circle fa-5x text-danger mb-3"></i>
                        <h4 class="text-light">Bartłomiej Szczypka</h4>
                        <p class="text-light">Trener Personalny & Nutritionist</p>
                        <p class="text-light small">Specjalizacja: trening siłowy kobiet, redukcja tkanki tłuszczowej</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-dark text-center h-100">
                    <div class="card-body">
                        <i class="fas fa-user-circle fa-5x text-danger mb-3"></i>
                        <h4 class="text-light">Kamil Szczypka</h4>
                        <p class="text-light">Head Coach CrossFit</p>
                        <p class="text-light small">Level 2 CrossFit Coach, przygotowanie zawodnicze</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-dark text-center h-100">
                    <div class="card-body">
                        <i class="fas fa-user-circle fa-5x text-danger mb-3"></i>
                        <h4 class="text-light">Lena Szczypka</h4>
                        <p class="text-light">Trener Yoga & Mobility</p>
                        <p class="text-light small">Poprawa ruchomości i regeneracja organizmu</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>