@{
    ViewBag.Title = "Oferta - Forge Fitness";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex align-items-center min-vh-100 pt-5">
    <div class="w-100">
        <h2 class="text-center display-5 fw-bold mb-5 text-light">Wybierz Swój Karnet</h2>
        
        <div class="row g-4 justify-content-center">
            <div class="col-lg-4 col-md-6">
                <div class="card bg-dark text-center h-100 border-secondary">
                    <div class="card-header bg-secondary py-3">
                        <h4 class="text-white">Basic</h4>
                    </div>
                    <div class="card-body">
                        <h2 class="text-light">139 zł <small class="fs-5">/mies.</small></h2>
                        <ul class="list-unstyled mt-4 text-light">
                            <li class="mb-2">✔ Dostęp 24/7</li>
                            <li class="mb-2">✔ Strefa siłowa + cardio</li>
                        </ul>
                        <a href="#" class="btn btn-outline-light w-100">Wybieram</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card bg-dark text-center h-100 border-danger shadow-lg">
                    <div class="card-header bg-danger py-3">
                        <h4 class="text-white">Premium <span class="badge bg-warning">NAJPOPULARNIEJSZY</span></h4>
                    </div>
                    <div class="card-body">
                        <h2 class="text-light">219 zł <small class="fs-5">/mies.</small></h2>
                        <ul class="list-unstyled mt-4 text-light">
                            <li class="mb-2">✔ Wszystko z Basic</li>
                            <li class="mb-2">✔ Wszystkie zajęcia grupowe</li>
                            <li class="mb-2">✔ 2 goście miesięcznie</li>
                        </ul>
                        <a href="#" class="btn btn-danger w-100">Wybieram</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card bg-dark text-center h-100 border-warning">
                    <div class="card-header bg-warning text-dark py-3">
                        <h4>VIP</h4>
                    </div>
                    <div class="card-body">
                        <h2 class="text-light">329 zł <small class="fs-5">/mies.</small></h2>
                        <ul class="list-unstyled mt-4 text-light">
                            <li class="mb-2">✔ Treningi personalne</li>
                            <li class="mb-2">✔ Sauna + solarium</li>
                            <li class="mb-2">✔ Priorytetowa rezerwacja</li>
                        </ul>
                        <a href="#" class="btn btn-outline-warning w-100">Wybieram</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>