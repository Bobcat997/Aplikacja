@{
    ViewBag.Title = "Zajęcia Grupowe - Forge Fitness";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex align-items-center min-vh-100 pt-5">
    <div class="w-100">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold text-light">Zajęcia Grupowe</h2>
            <p class="lead text-light">Ponad 30 zajęć tygodniowo • Dołącz do najlepszej atmosfery w mieście</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card bg-dark border-danger h-100 text-center">
                    <div class="card-body p-4">
                        <h4 class="text-light">CrossFit</h4>
                        <p class="text-light">Pon, Śr, Pt<br><strong>18:00 - 19:00</strong></p>
                        <span class="badge bg-danger">Zaawansowany</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-dark border-danger h-100 text-center">
                    <div class="card-body p-4">
                        <h4 class="text-light">Yoga</h4>
                        <p class="text-light">Wt, Czw<br><strong>17:30 - 18:30</strong></p>
                        <span class="badge bg-danger">Początkujący / Średni</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-dark border-danger h-100 text-center">
                    <div class="card-body p-4">
                        <h4 class="text-light">Spinning</h4>
                        <p class="text-light">Codziennie<br><strong>19:00 - 20:00</strong></p>
                        <span class="badge bg-danger">Cardio</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>