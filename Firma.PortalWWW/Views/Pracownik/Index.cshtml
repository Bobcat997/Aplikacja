@model IEnumerable<Firma.Data.Entities.Pracownik>
@{
    ViewBag.Title = "Pracownicy";
}

<h2><i class="fas fa-users"></i> Nasi Pracownicy</h2>

<div class="row mb-4">
    <div class="col-md-6">
        <form asp-action="Index" method="get">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Szukaj pracownika..." value="@ViewBag.Search" />
                <button class="btn btn-primary" type="submit">Szukaj</button>
            </div>
        </form>
    </div>
</div>

<table class="table table-hover table-striped align-middle">
    <thead class="table-dark">
        <tr>
            <th>Imię i Nazwisko</th>
            <th>Dział</th>
            <th>Stanowisko</th>
            <th>Email</th>
            <th>Telefon</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Imie @item.Nazwisko</strong></td>
                <td>@item.Dzial?.Nazwa</td>
                <td>@item.Stanowisko?.Nazwa</td>
                <td>@item.Email</td>
                <td>@item.Telefon</td>
            </tr>
        }
    </tbody>
</table>